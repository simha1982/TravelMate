<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelMate.Mobile.MainPage"
             Title="TravelMate">

    <ScrollView>
        <VerticalStackLayout Padding="22" Spacing="18">
            <Label
                Text="TravelMate"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Nearby stories for the road ahead"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2" />

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Connection"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <Entry
                        x:Name="ApiBaseUrlEntry"
                        Placeholder="API base URL" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Text="Save API URL"
                            Clicked="OnSaveApiUrlClicked" />
                        <Button
                            Grid.Column="1"
                            Text="Test connection"
                            Clicked="OnTestConnectionClicked" />
                    </Grid>
                    <Label
                        x:Name="ApiStatusLabel"
                        Text=""
                        FontSize="13" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Demo location"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <Picker
                        x:Name="DemoLocationPicker"
                        Title="Choose a demo place" />
                    <Button
                        Text="Load demo stories"
                        Clicked="OnLoadDemoLocationClicked"
                        HorizontalOptions="Fill" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button
                            Text="Start demo trip"
                            Clicked="OnStartDemoTripClicked" />
                        <Button
                            Grid.Column="1"
                            Text="Next stop"
                            Clicked="OnNextDemoStopClicked" />
                    </Grid>
                    <Label
                        x:Name="LocationLabel"
                        Text="No location selected yet."
                        FontSize="13" />
                    <WebView
                        x:Name="MapPreview"
                        HeightRequest="180" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Find stories near me"
                Clicked="OnFindStoriesClicked"
                HorizontalOptions="Fill" />

            <Label
                x:Name="StatusLabel"
                Text="Use travel mode to fetch your location and ask the API for nearby stories."
                FontSize="14" />

            <CollectionView
                x:Name="StoriesCollection"
                HeightRequest="360"
                SelectionMode="Single"
                SelectionChanged="OnStorySelectionChanged">
                <CollectionView.EmptyView>
                    <Label
                        Text="Nearby story cards will appear here."
                        FontSize="14" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1" Padding="14" Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="{Binding PlaceName}"
                                    FontAttributes="Bold"
                                    FontSize="15" />
                                <Label
                                    Text="{Binding Title}"
                                    FontAttributes="Bold"
                                    FontSize="17" />
                                <Label
                                    Text="{Binding ShortDescription}"
                                    FontSize="13" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label
                                        Text="{Binding DistanceMeters, StringFormat='{0:0} m'}"
                                        FontSize="12" />
                                    <Label
                                        Text="{Binding Score, StringFormat='Score {0:0.00}'}"
                                        FontSize="12" />
                                    <Label
                                        Text="{Binding SourceName}"
                                        FontSize="12" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border StrokeThickness="1" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label
                        x:Name="PlaceLabel"
                        Text="No story selected"
                        FontAttributes="Bold"
                        FontSize="18" />
                    <Label
                        x:Name="StoryTitleLabel"
                        Text=""
                        FontSize="16" />
                    <Label
                        x:Name="StoryDescriptionLabel"
                        Text=""
                        FontSize="14" />
                    <Label
                        x:Name="StoryDetailLabel"
                        Text=""
                        FontSize="13" />
                    <toolkit:MediaElement
                        x:Name="StoryPlayer"
                        HeightRequest="72"
                        ShouldAutoPlay="False"
                        ShouldShowPlaybackControls="True"
                        MediaEnded="OnStoryPlayerMediaEnded" />
                    <HorizontalStackLayout Spacing="10">
                        <Button
                            Text="Previous"
                            Clicked="OnPreviousStoryClicked" />
                        <Button
                            Text="Next"
                            Clicked="OnNextStoryClicked" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Button
                            Text="Play"
                            Clicked="OnPlayClicked" />
                        <Button
                            Text="Interested"
                            Clicked="OnInterestedClicked" />
                        <Button
                            Text="Not interested"
                            Clicked="OnNotInterestedClicked" />
                        <Button
                            Text="Skip"
                            Clicked="OnSkipClicked" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="10">
                        <Button
                            Text="Open source"
                            Clicked="OnOpenSourceClicked" />
                        <Button
                            Text="Open map"
                            Clicked="OnOpenMapClicked" />
                    </HorizontalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry
                            x:Name="VoiceCommandEntry"
                            Placeholder="Command: yes / no / play / skip" />
                        <Button
                            Grid.Column="1"
                            Text="Run"
                            Clicked="OnVoiceCommandClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Entry
                x:Name="QuestionEntry"
                Placeholder="Ask about nearby stories" />

            <Button
                Text="Ask TravelMate"
                Clicked="OnAskClicked" />

            <Label
                x:Name="AnswerLabel"
                Text=""
                FontSize="14" />

            <Button
                Text="Play answer"
                Clicked="OnPlayAnswerClicked" />

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Preferences"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                        <HorizontalStackLayout Spacing="6">
                            <CheckBox x:Name="HistoryPreference" IsChecked="True" />
                            <Label Text="History" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="6">
                            <CheckBox x:Name="NaturePreference" IsChecked="True" />
                            <Label Text="Nature" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Spacing="6">
                            <CheckBox x:Name="ArchitecturePreference" IsChecked="True" />
                            <Label Text="Architecture" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                            <CheckBox x:Name="CricketPreference" />
                            <Label Text="Cricket" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="2" Spacing="6">
                            <CheckBox x:Name="FoodPreference" />
                            <Label Text="Food" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                            <CheckBox x:Name="CulturePreference" IsChecked="True" />
                            <Label Text="Culture" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                    <Picker
                        x:Name="LanguagePicker"
                        Title="Preferred language" />
                    <Button
                        Text="Save preferences"
                        Clicked="OnSavePreferencesClicked" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Privacy and consent"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <HorizontalStackLayout Spacing="8">
                        <Switch x:Name="LocationConsentSwitch" IsToggled="True" />
                        <Label Text="Location" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Switch x:Name="VoiceConsentSwitch" />
                        <Label Text="Voice" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Switch x:Name="PersonalizationConsentSwitch" IsToggled="True" />
                        <Label Text="Personalization" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Button
                        Text="Save consent"
                        Clicked="OnSaveConsentClicked" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Contribute a story"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <Entry
                        x:Name="ContributionPlaceEntry"
                        Placeholder="Place name" />
                    <Entry
                        x:Name="ContributionTitleEntry"
                        Placeholder="Story title" />
                    <Editor
                        x:Name="ContributionTextEditor"
                        Placeholder="Tell the story in a few sentences"
                        AutoSize="TextChanges"
                        HeightRequest="120" />
                    <Button
                        Text="Submit contribution"
                        Clicked="OnSubmitContributionClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
