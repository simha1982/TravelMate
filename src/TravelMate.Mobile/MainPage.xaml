<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelMate.Mobile.MainPage"
             Title="TravelMate">

    <ScrollView>
        <VerticalStackLayout Padding="22" Spacing="18">
            <Label
                Text="TravelMate"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Nearby stories for the road ahead"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2" />

            <Border StrokeThickness="1" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Demo location"
                        FontAttributes="Bold"
                        FontSize="16" />
                    <Picker
                        x:Name="DemoLocationPicker"
                        Title="Choose a demo place" />
                    <Button
                        Text="Load demo stories"
                        Clicked="OnLoadDemoLocationClicked"
                        HorizontalOptions="Fill" />
                    <Label
                        x:Name="LocationLabel"
                        Text="No location selected yet."
                        FontSize="13" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Find stories near me"
                Clicked="OnFindStoriesClicked"
                HorizontalOptions="Fill" />

            <Label
                x:Name="StatusLabel"
                Text="Use travel mode to fetch your location and ask the API for nearby stories."
                FontSize="14" />

            <CollectionView
                x:Name="StoriesCollection"
                HeightRequest="360"
                SelectionMode="Single"
                SelectionChanged="OnStorySelectionChanged">
                <CollectionView.EmptyView>
                    <Label
                        Text="Nearby story cards will appear here."
                        FontSize="14" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1" Padding="14" Margin="0,0,0,10">
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="{Binding PlaceName}"
                                    FontAttributes="Bold"
                                    FontSize="15" />
                                <Label
                                    Text="{Binding Title}"
                                    FontAttributes="Bold"
                                    FontSize="17" />
                                <Label
                                    Text="{Binding ShortDescription}"
                                    FontSize="13" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label
                                        Text="{Binding DistanceMeters, StringFormat='{0:0} m'}"
                                        FontSize="12" />
                                    <Label
                                        Text="{Binding Score, StringFormat='Score {0:0.00}'}"
                                        FontSize="12" />
                                    <Label
                                        Text="{Binding SourceName}"
                                        FontSize="12" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border StrokeThickness="1" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label
                        x:Name="PlaceLabel"
                        Text="No story selected"
                        FontAttributes="Bold"
                        FontSize="18" />
                    <Label
                        x:Name="StoryTitleLabel"
                        Text=""
                        FontSize="16" />
                    <Label
                        x:Name="StoryDescriptionLabel"
                        Text=""
                        FontSize="14" />
                    <toolkit:MediaElement
                        x:Name="StoryPlayer"
                        HeightRequest="72"
                        ShouldAutoPlay="False"
                        ShouldShowPlaybackControls="True" />
                    <HorizontalStackLayout Spacing="10">
                        <Button
                            Text="Play"
                            Clicked="OnPlayClicked" />
                        <Button
                            Text="Interested"
                            Clicked="OnInterestedClicked" />
                        <Button
                            Text="Skip"
                            Clicked="OnSkipClicked" />
                    </HorizontalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry
                            x:Name="VoiceCommandEntry"
                            Placeholder="Command: yes / no / play / skip" />
                        <Button
                            Grid.Column="1"
                            Text="Run"
                            Clicked="OnVoiceCommandClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Entry
                x:Name="QuestionEntry"
                Placeholder="Ask about nearby stories" />

            <Button
                Text="Ask TravelMate"
                Clicked="OnAskClicked" />

            <Label
                x:Name="AnswerLabel"
                Text=""
                FontSize="14" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
