@page
@model StoriesModel
@{
    ViewData["Title"] = "Stories";
}

<section class="page-heading">
    <div>
        <h1>Stories</h1>
        <p>Browse seeded and curated TravelMate story content.</p>
    </div>
    <div class="queue-count">
        <span>@Model.Summary.StoryCount</span>
        <small>stories</small>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="notice notice-error">@Model.ErrorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="notice notice-success">@Model.StatusMessage</div>
}

<section class="metric-grid compact">
    <article class="metric-card">
        <span>Places</span>
        <strong>@Model.Summary.PlaceCount</strong>
    </article>
    <article class="metric-card">
        <span>Wikipedia</span>
        <strong>@Model.Summary.WikipediaStoryCount</strong>
    </article>
    <article class="metric-card">
        <span>Languages</span>
        <strong>@Model.Stories.Select(item => item.Story.LanguageCode).Distinct().Count()</strong>
    </article>
</section>

<section class="content-management">
    <details>
        <summary>Add place</summary>
        <form method="post" class="admin-form">
            <div class="form-grid">
                <label>Name <input asp-for="CreatePlace.Name" required /></label>
                <label>Country <input asp-for="CreatePlace.Country" required /></label>
                <label>Region <input asp-for="CreatePlace.Region" required /></label>
                <label>Latitude <input asp-for="CreatePlace.Latitude" type="number" step="0.0001" required /></label>
                <label>Longitude <input asp-for="CreatePlace.Longitude" type="number" step="0.0001" required /></label>
                <label>Categories <input asp-for="CreatePlace.Categories" /></label>
            </div>
            <button type="submit" asp-page-handler="CreatePlace" class="btn-approve">Create place</button>
        </form>
    </details>
    <details>
        <summary>Edit places</summary>
        <div class="place-edit-list">
            @foreach (var place in Model.Places.OrderBy(place => place.Region).ThenBy(place => place.Name))
            {
                <form method="post" class="admin-form compact-form">
                    <input type="hidden" name="EditPlace.Id" value="@place.Id" />
                    <label>Name <input name="EditPlace.Name" value="@place.Name" required /></label>
                    <label>Country <input name="EditPlace.Country" value="@place.Country" required /></label>
                    <label>Region <input name="EditPlace.Region" value="@place.Region" required /></label>
                    <label>Latitude <input name="EditPlace.Latitude" type="number" step="0.0001" value="@place.Location.Latitude" required /></label>
                    <label>Longitude <input name="EditPlace.Longitude" type="number" step="0.0001" value="@place.Location.Longitude" required /></label>
                    <label>Categories <input name="EditPlace.Categories" value="@string.Join(",", place.Categories)" /></label>
                    <button type="submit" asp-page-handler="UpdatePlace" class="btn-approve">Save place</button>
                </form>
            }
        </div>
    </details>
    <details>
        <summary>Add story</summary>
        <form method="post" class="admin-form">
            <div class="form-grid">
                <label>
                    Place
                    <select asp-for="CreateStory.PlaceId" required>
                        @foreach (var place in Model.Places.OrderBy(place => place.Region).ThenBy(place => place.Name))
                        {
                            <option value="@place.Id">@place.Region - @place.Name</option>
                        }
                    </select>
                </label>
                <label>Title <input asp-for="CreateStory.Title" required /></label>
                <label>Language <input asp-for="CreateStory.LanguageCode" required /></label>
                <label>Categories <input asp-for="CreateStory.Categories" /></label>
                <label>Source name <input asp-for="CreateStory.SourceName" required /></label>
                <label>Source URL <input asp-for="CreateStory.SourceUrl" required /></label>
                <label>Quality <input asp-for="CreateStory.QualityScore" type="number" min="0" max="100" /></label>
                <label>Audio URL <input asp-for="CreateStory.AudioUrl" /></label>
            </div>
            <label class="wide-field">Description <textarea asp-for="CreateStory.ShortDescription" required></textarea></label>
            <button type="submit" asp-page-handler="CreateStory" class="btn-approve">Create story</button>
        </form>
    </details>
</section>

@if (Model.Stories.Count == 0 && string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="empty-state">
        <h2>No stories found</h2>
        <p>Seeded stories will appear here after the API starts.</p>
    </div>
}
else
{
    <div class="story-list">
        @foreach (var row in Model.Stories)
        {
            <article class="story-card">
                <div class="story-card-main">
                    <div class="row-meta">
                        <span>@(row.Place?.Region ?? "Unknown region")</span>
                        <span>@(row.Place?.Name ?? "Unknown place")</span>
                        <span>@row.Story.LanguageCode</span>
                    </div>
                    <h2>@row.Story.Title</h2>
                    <p>@row.Story.ShortDescription</p>
                    <div class="chip-row">
                        @foreach (var category in row.Story.Categories)
                        {
                            <span class="chip">@category</span>
                        }
                    </div>
                </div>
                <aside class="story-card-side">
                    <dl>
                        <div>
                            <dt>Quality</dt>
                            <dd>@row.Story.QualityScore</dd>
                        </div>
                        <div>
                            <dt>Source</dt>
                            <dd>
                                <a href="@row.Story.SourceUrl" target="_blank" rel="noreferrer">@row.Story.SourceName</a>
                            </dd>
                        </div>
                        <div>
                            <dt>Audio</dt>
                            <dd>@(string.IsNullOrWhiteSpace(row.Story.AudioUrl) ? "Not generated" : "Available")</dd>
                        </div>
                    </dl>
                </aside>
                <details class="edit-panel">
                    <summary>Edit story</summary>
                    <form method="post" class="admin-form compact-form">
                        <input type="hidden" name="EditStory.Id" value="@row.Story.Id" />
                        <input type="hidden" name="EditStory.PlaceId" value="@row.Story.PlaceId" />
                        <label>Title <input name="EditStory.Title" value="@row.Story.Title" required /></label>
                        <label>Description <textarea name="EditStory.ShortDescription" required>@row.Story.ShortDescription</textarea></label>
                        <label>Language <input name="EditStory.LanguageCode" value="@row.Story.LanguageCode" required /></label>
                        <label>Categories <input name="EditStory.Categories" value="@string.Join(",", row.Story.Categories)" /></label>
                        <label>Source name <input name="EditStory.SourceName" value="@row.Story.SourceName" required /></label>
                        <label>Source URL <input name="EditStory.SourceUrl" value="@row.Story.SourceUrl" required /></label>
                        <label>Audio URL <input name="EditStory.AudioUrl" value="@row.Story.AudioUrl" /></label>
                        <label>Quality <input name="EditStory.QualityScore" type="number" min="0" max="100" value="@row.Story.QualityScore" /></label>
                        <button type="submit" asp-page-handler="UpdateStory" class="btn-approve">Save story</button>
                    </form>
                </details>
            </article>
        }
    </div>
}
