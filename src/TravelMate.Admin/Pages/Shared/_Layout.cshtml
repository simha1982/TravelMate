<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelMate Admin</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TravelMate.Admin.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="admin-nav">
            <div class="nav-inner">
                <a class="navbar-brand" asp-area="" asp-page="/Index">TravelMate Admin</a>
                <a class="nav-link" asp-area="" asp-page="/Index">Moderation</a>
                <a class="nav-link" asp-area="" asp-page="/AiUsage">AI Usage</a>
            </div>
        </nav>
    </header>
    <div class="admin-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
